  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 8px;
  -webkit-transition: 0.4s;
  transition: 0.4s;
}
.switch .slider:before {
  position: absolute;
  content: '';
  height: 10px;
  width: 10px;
  left: 3px;
  bottom: 3px;
  border-radius: 50%;
  -webkit-transition: 0.4s;
  transition: 0.4s;
}
